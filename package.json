{
  "name": "comnumbers",
  "version": "1.1.1",
  "description": "A tiny, zero-dependency utility to convert human-readable time strings to milliseconds and back.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "unpkg": "dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.js",
    "default": "./dist/index.js"
  },
  "type": "module",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "swc src/index.js -o dist/index.js --config-file .swcrc.json",
    "test": "node test.js",
    "format": "prettier --write ."
  },
  "keywords": [
    "utility",
    "numbers",
    "time",
    "ms",
    "convert",
    "humanize"
  ],
  "author": "oopsio",
  "license": "MIT",
  "devDependencies": {
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.21",
    "ms": "^2.1.3"
  },
  "trustedDependencies": [
    "@swc/core"
  ]
}
